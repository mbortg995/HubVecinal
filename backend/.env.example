# Copia este archivo a .env y ajusta los valores
PORT=4000
MONGODB_URI=mongodb://localhost:27017/hubvecinal
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
JWT_EXPIRES_IN=7d
CLIENT_ORIGIN=http://localhost:5173

# Email (opcional). Si SMTP_HOST está vacío, los emails se registran en consola (modo dev).
EMAIL_FROM=HubVecinal <no-reply@hubvecinal.dev>
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Subida de archivos
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=10
